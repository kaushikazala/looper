--Q1.
  #include <iostream>
using namespace std;

int main() {
    char ch = 'a';

    do {
        cout << ch << " ";
        ch = ch + 4;
    } while (ch <= 'z');

    return 0;
}

--Q2.

#include <iostream>
using namespace std;

int main() {
    int num = 123;
    int count = 0;

    while (num != 0) {
        num = num / 10;
        count++;
    }

    cout << "Total digits = " << count;
    return 0;
}

--Q3.

#include <iostream>
using namespace std;

int main() {
    int num = 12345;
    
    int last = num % 10; 
    int first = num;

    // get first digit
    while (first >= 10) {
        first = first / 10;
    }

    int sum = first + last;

    cout << "First digit = " << first << endl;
    cout << "Last digit = " << last << endl;
    cout << "Sum = " << sum;

    return 0;
}
